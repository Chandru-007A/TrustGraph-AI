# Port number
PORT=8080

# Environment
NODE_ENV=development

# URL of the PostgreSQL/Supabase database
DATABASE_URL="postgresql://postgres:password@localhost:5432/leo_db?schema=public"

# CORS Origin
CORS_ORIGIN=http://localhost:3000

# JWT configuration
JWT_SECRET=thisisasamplesecret
JWT_ACCESS_EXPIRATION_MINUTES=30
JWT_REFRESH_EXPIRATION_DAYS=30

# x402 Coinbase Payment Protocol
X402_FACILITATOR_URL=https://api.coinbase.com/v2/x402/facilitator
X402_NETWORK=eip155:8453
X402_SELLER_ADDRESS=0x5e11e80000000000000000000000000000000000
USDC_TOKEN_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# ─────────────────────────────────────────────────────────────────────────────
# Circle Gateway — Unified Balance (payment backend for x402)
# Leave KIT_KEY empty to run in MOCK mode (synthesized success, no chain).
# Fill in to enable live Unified Balance operations.
# ─────────────────────────────────────────────────────────────────────────────
GATEWAY_ENABLED=false
KIT_KEY=
CIRCLE_GATEWAY_KEY=
GATEWAY_RPC_URL=
GATEWAY_WALLET_PRIVATE_KEY=
GATEWAY_WEBHOOK_SECRET=
GATEWAY_DELEGATE_ADDRESS=
UNIFIED_BALANCE_NETWORK=Arc_Testnet

