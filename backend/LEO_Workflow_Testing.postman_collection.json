      }
    }
  ],
  "variable": [
    { "key": "FIRST_HASH_VALUE", "value": "" },
    { "key": "FIRST_NODE_ID", "value": "" },
    { "key": "MERKLE_ROOT_HASH", "value": "" },
    { "key": "MERKLE_PROOF_LEAF_HASH", "value": "" },
