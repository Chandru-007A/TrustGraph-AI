        "url": { "raw": "{{BASE_URL}}/blockchain/retry", "host": ["{{BASE_URL}}"], "path": ["blockchain", "retry"] }
      }
    },
    {
      "name": "🔗 25. Register Merkle Root",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"workflowId\": \"{{SESSION_ID}}\"\n}"
        },
        "url": { "raw": "{{BASE_URL}}/receipt/register", "host": ["{{BASE_URL}}"], "path": ["receipt", "register"] }
      }
    },
    {
      "name": "🔗 26. Get Receipt",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}" }
        ],
        "url": { "raw": "{{BASE_URL}}/receipt/{{SESSION_ID}}", "host": ["{{BASE_URL}}"], "path": ["receipt", "{{SESSION_ID}}"] }
      }
    },
    {
      "name": "🔗 27. Get Receipt Status",
      "request": {
